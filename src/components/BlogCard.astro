---
// BlogCard.astro
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
  image?: string;
}

const { title, description, pubDate, category, slug, image } = Astro.props;

const rawDate = pubDate.toLocaleDateString('es-MX', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const formattedDate = rawDate.charAt(0).toUpperCase() + rawDate.slice(1);
---

<article class="blog-card" aria-label={title}>
  <a href={`/blog/${slug}`} class="blog-card-link" id={`blog-card-${slug}`}>

    {image && (
      <div class="blog-card-image">
        <img src={image} alt={title} loading="lazy" width="400" height="225" />
      </div>
    )}

    <div class="blog-card-content">
      <header class="blog-card-header">
        <span class="badge">{category}</span>
        <time
          class="blog-card-date"
          datetime={pubDate.toISOString()}
          aria-label={`Publicado el ${formattedDate}`}
        >
          {formattedDate}
        </time>
      </header>

      <div class="blog-card-body">
        <h3 class="blog-card-title">{title}</h3>
        <p class="blog-card-desc">{description}</p>
      </div>

      <footer class="blog-card-footer">
        <span class="read-more">
          Leer artículo
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </span>
      </footer>
    </div>
  </a>
</article>

<style>
  .blog-card {
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
    background: var(--bg-card);
    transition: var(--transition);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .blog-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-accent);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.05);
    transform: translateY(-3px);
  }

  .blog-card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    height: 100%;
  }

  /* Imagen de portada */
  .blog-card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .blog-card:hover .blog-card-image img {
    transform: scale(1.04);
  }

  /* Contenido */
  .blog-card-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    flex: 1;
  }

  .blog-card-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.45rem;
  }

  .blog-card-date {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .blog-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .blog-card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.2s;
  }

  .blog-card:hover .blog-card-title {
    color: var(--accent);
  }

  .blog-card-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-footer {
    margin-top: 0.25rem;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    transition: gap 0.2s;
  }

  .blog-card:hover .read-more {
    gap: 0.6rem;
  }
</style>
