  }
  .si-pad-act {
    display: flex; gap: 0.5rem; flex: 1; justify-content: flex-end;
  }
  .si-btn {
    min-width: 60px;
    padding: 0.85rem 0.9rem;
    background: rgba(192, 20, 42, 0.25);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    font-family: var(--font-mono, 'JetBrains Mono'), monospace;
    font-size: 0.85rem; font-weight: 700;
    letter-spacing: 0.08em;
    cursor: pointer;
    user-select: none; -webkit-user-select: none;
    touch-action: manipulation;
  }
  .si-btn:active { background: #c0142a; border-color: #ff3a44; }
  .si-btn-fire { background: #c0142a; flex: 1.2; }
  .si-btn-fire:active { background: #ff3a44; }
  .si-hint {
    margin: 0;
    font-family: var(--font-mono, 'JetBrains Mono'), monospace;
    font-size: 0.7rem; color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.08em; text-align: center;
  }
  @media (max-width: 700px) {
    .si-frame { padding: 0.7rem; gap: 0.5rem; }
