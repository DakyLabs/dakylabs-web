---
// Footer.astro
import SpaceInvaders from './SpaceInvaders.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" class="logo" aria-label="DakyLabs">
        <svg
          width="24"
          height="24"
          viewBox="0 0 28 28"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <rect width="28" height="28" rx="6" fill="#c0142a"></rect>
          <path
            d="M8 20V8h5.5c3.87 0 6.5 2.46 6.5 6s-2.63 6-6.5 6H8zm3-2.6h2.4c2.2 0 3.6-1.3 3.6-3.4s-1.4-3.4-3.6-3.4H11v6.8z"
            fill="white"></path>
        </svg>
        <span>akyLabs</span>
      </a>
      <p class="footer-tagline">Cloud e IA.</p>
    </div>

    <!-- Links -->
    <nav class="footer-nav" aria-label="Links del footer">
      <div class="footer-col">
        <h4 class="footer-col-title">Páginas</h4>
        <ul role="list">
          <li><a href="/">Inicio</a></li>
          <li><a href="/servicios">Lo que construyo</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4 class="footer-col-title">Contacto</h4>
        <ul role="list">
          <li>
            <a href="mailto:contacto@dakylabs.com" id="footer-email-link">
              contacto@dakylabs.com
            </a>
          </li>
        </ul>
      </div>
      <div class="footer-col">
        <h4 class="footer-col-title">Comunidad</h4>
        <ul role="list">
          <li>
            <a
              href="https://youtube.com/@dakylabs"
              target="_blank"
              rel="noopener noreferrer"
              id="footer-youtube-link"
              class="social-link"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1C4.5 20.5 12 20.5 12 20.5s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.8 15.5V8.5l6.2 3.5-6.2 3.5z"
                ></path>
              </svg>
              YouTube
            </a>
          </li>
          <li>
            <a
              href="https://github.com/dakylabs"
              target="_blank"
              rel="noopener noreferrer"
              id="footer-github-link"
              class="social-link"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.7 18 5 18 5c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3z"
                ></path>
              </svg>
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </nav>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {year} DakyLabs. Todos los derechos reservados.</p>
      <SpaceInvaders />
      <p class="footer-bottom-right">Hecho con ❤ por DakyLabs.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #111114;
    border-top: 1px solid rgba(255,255,255,0.08);
    margin-top: var(--space-3xl);
    position: relative;
    z-index: 1;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    padding-block: 3.5rem;
  }

  /* Brand */
  .footer-brand .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.1rem;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #EFEFEF;
    margin-bottom: 0.75rem;
    text-decoration: none;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: #68686F;
    line-height: 1.6;
    max-width: 22ch;
  }

  /* Nav columns */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-col-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #68686F;
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-col a {
    font-size: 0.875rem;
    color: #A0A0A8;
    transition: color 0.2s;
    text-decoration: none;
  }
  .footer-col a:hover {
    color: #EFEFEF;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-block: 1.25rem;
  }

  .footer-bottom .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: #68686F;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-block: 2.5rem;
    }

    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-bottom .container {
      flex-direction: column;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .footer-nav {
      grid-template-columns: 1fr;
    }
  }
</style>
