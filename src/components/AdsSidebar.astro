---
// AdsSidebar.astro — columna de anuncios (foto grande + título)
import { ads } from '../data/ads';
---

{ads.length > 0 && (
  <div class="as-widget">
    {ads.map((ad) => (
      <a href={ad.url} target="_blank" rel="noopener noreferrer" class="as-card">
        <p class="as-title">{ad.title}</p>
        <div class="as-img-wrap">
          <img src={ad.image} alt={ad.title} loading="lazy" width="200" height="260" />
        </div>
      </a>
    ))}
  </div>
)}
