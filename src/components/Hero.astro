---
// Hero.astro
import HeroSpace from './HeroSpace.astro';
---

<section class="hero" id="hero" aria-label="Sección principal">
  <!-- DakyBot Background con canvas 3D detrás (isolation group) -->
  <div class="hero-bot-wrapper" aria-hidden="true">
    <!-- 3D Space Background (Three.js) — hermano del robot para que el
         blend-mode pueda verlo como backdrop -->
    <HeroSpace />
    <img
      src="/images/dakybot-hero.png"
      alt=""
      class="hero-bot"
      width="750"
      height="750"
      loading="eager"
      decoding="async"
    />
    <div class="hero-bot-glow"></div>
  </div>

  <!-- Overlay lateral para mejorar legibilidad del texto -->
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Red ambient light at bottom of bot -->
  <div class="hero-ambient" aria-hidden="true"></div>

  <!-- Content -->
  <div class="container hero-content">

    <!-- Bio card -->
    <div class="hero-bio animate-fade-up delay-3">
      <img
        src="/images/santino-avatar.jpg"
        alt="Santino Suntaxi"
        class="hero-bio-avatar"
        width="52"
        height="52"
        loading="eager"
      />
      <div class="hero-bio-body">
        <div class="hero-bio-header">
          <strong class="hero-bio-name">Santino Suntaxi</strong>
          <span class="hero-bio-role">Cloud & Automation Engineer · IA aplicada</span>
        </div>
        <p class="hero-bio-text">
          Primero el problema, luego la herramienta.
        </p>
        <div class="hero-bio-links">
          <a href="https://github.com/DakyLabs/" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/santinosuntaxi/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <a href="https://youtube.com/@dakylabs" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
          <a href="https://discord.com/invite/RJtQCFCgy" target="_blank" rel="noopener noreferrer" aria-label="Discord">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="hero-actions animate-fade-up delay-2">
      <a href="/blog" class="btn btn-primary btn-hero" id="hero-cta-btn">
        Leer artículos
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
          style="margin-left: 8px;"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
      <a href="/bio" class="btn btn-ghost" id="hero-services-btn"> Sobre mí </a>
    </div>

    <h1 class="hero-title animate-fade-up delay-3">
      No es Magia<br />
      <span class="hero-title-accent">Es Ingeniería</span>
    </h1>

    <p class="hero-subtitle animate-fade-up delay-3">
      Escribo sobre lo que construyo, lo que rompo<br class="desktop-only" />
      y lo que aprendo en el proceso.
    </p>

  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <span class="scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    /* Full-bleed: se extiende al ancho completo del viewport desde dentro de la columna central */
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    /* Estilos visuales */
    min-height: 560px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-block: 4rem 3.5rem;
    background:
      radial-gradient(ellipse 90% 60% at 50% 55%, rgba(70, 10, 22, 0.22) 0%, transparent 62%),
      #080506;
    margin-bottom: 0;
  }

  /* ── DakyBot Background ────────────────────────────────── */
  .hero-bot-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
    /* Grupo de blend: el canvas (primer hijo) y el robot son hermanos
       acá, así que mix-blend-mode del robot ve al canvas como backdrop. */
    isolation: isolate;
  }

  .hero-bot {
    width: min(520px, 75vw);
    height: auto;
    object-fit: contain;
    opacity: 1;
    filter: saturate(1.15);
    transform: translateY(0%);
    /* Máscara radial: borra el rectángulo de la JPEG. Centro 100% opaco,
       bordes se desvanecen a transparente — la silueta del robot queda
       crujiente, el cielo estrellado aparece alrededor. */
    mask-image: radial-gradient(
      ellipse 48% 68% at 50% 46%,
      black 52%,
      transparent 100%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 48% 68% at 50% 46%,
      black 52%,
      transparent 100%
    );
    /* Lighten: los píxeles oscuros del fondo JPEG dejan pasar las
       estrellas brillantes detrás; el robot iluminado se queda. */
    mix-blend-mode: lighten;
  }

  .hero-bot-glow {
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(
      circle,
      rgba(192, 20, 42, 0.22) 0%,
      transparent 70%
    );
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -35%);
    pointer-events: none;
  }

  /* ── Overlay lateral: oscurece el lado del texto ──────── */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.28) 0%,
      rgba(0, 0, 0, 0.10) 40%,
      transparent 65%
    );
    pointer-events: none;
    z-index: 1;
  }

  /* ── Ambient red bottom glow ───────────────────────────── */
  .hero-ambient {
    position: absolute;
    bottom: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 300px;
    background: radial-gradient(
      ellipse,
      rgba(192, 20, 42, 0.18) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* ── Content ───────────────────────────────────────────── */
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    max-width: 820px;
    margin-inline: auto;
  }

  .hero-eyebrow {
    margin-bottom: 1.75rem;
  }

  /* ── Title ─────────────────────────────────────────────── */
  .hero-title {
    font-size: clamp(2rem, 5vw, 3.6rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: rgba(255, 255, 255, 0.93);
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .hero-title-accent {
    color: #E8374F;   /* rojo más vivo — contrasta bien sobre el azul oscuro */
  }

  /* ── Subtitle ──────────────────────────────────────────── */
  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: rgba(255, 255, 255, 0.62);
    max-width: 52ch;
    line-height: 1.75;
    margin-bottom: 0;
  }

  /* ── Actions ───────────────────────────────────────────── */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-hero {
    padding: 0.9rem 2.25rem;
    font-size: 1rem;
    animation: pulse-glow 3s ease-in-out infinite;
  }

  .btn-hero:hover {
    animation: none;
  }

  /* btn-ghost dentro del hero: fondo oscuro, necesita letras claras */
  .hero-actions .btn-ghost {
    color: rgba(255, 255, 255, 0.75);
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.06);
  }
  .hero-actions .btn-ghost:hover {
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.12);
  }

  /* ── Stats ─────────────────────────────────────────────── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-number {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--border-subtle);
    flex-shrink: 0;
  }

  /* ── Bio card ──────────────────────────────────────────── */
  .hero-bio {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-top: 0;
    margin-bottom: 1.5rem;
    padding: 1.1rem 1.4rem;
    background: rgba(0, 0, 0, 0.22);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    backdrop-filter: blur(20px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-md);
    max-width: 520px;
    text-align: left;
  }

  .hero-bio-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center 15%;
    flex-shrink: 0;
    border: 2px solid rgba(255, 255, 255, 0.18);
  }

  .hero-bio-body {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    min-width: 0;
  }

  .hero-bio-header {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .hero-bio-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.98);
    line-height: 1.2;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.75), 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .hero-bio-role {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.78);
    font-family: var(--font-mono);
    line-height: 1.4;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.7), 0 2px 8px rgba(0, 0, 0, 0.45);
  }

  .hero-bio-text {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.65;
    margin: 0;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.7), 0 2px 8px rgba(0, 0, 0, 0.45);
  }

  .hero-bio-links {
    display: flex;
    gap: 0.85rem;
    margin-top: 0.25rem;
  }

  .hero-bio-links a {
    color: rgba(255, 255, 255, 0.45);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .hero-bio-links a:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  /* ── Scroll indicator — oculto ahora que hero está en columna ── */
  .scroll-indicator {
    display: none;
  }

  .scroll-line {
    display: none;
  }

  .desktop-only {
    display: none;
  }

  @media (min-width: 768px) {
    .desktop-only {
      display: block;
    }
  }

  @media (max-width: 640px) {
    /* ── Layout mobile: robot arriba, texto superpuesto al centro ── */
    .hero {
      min-height: 100svh;
      padding-top: 0;
      padding-bottom: 22svh; /* empuja el texto hasta el centro del robot */
      justify-content: flex-end;
    }

    /* Wrapper: solo ocupa la mitad superior — NO cubre el hero completo */
    .hero-bot-wrapper {
      bottom: auto; /* cancela el inset:0 en la parte inferior */
      height: 46svh; /* techo exacto para el robot */
      overflow: hidden;
      align-items: flex-start;
    }

    /* Robot llena el wrapper con crop desde arriba (cabeza visible) */
    .hero-bot {
      width: 100%;
      height: 100%;
      max-height: none; /* anula el valor desktop */
      object-fit: cover;
      object-position: center top;
      opacity: 0.75;
      transform: none;
      mask-image: linear-gradient(
        to bottom,
        black 45%,
        rgba(0, 0, 0, 0.5) 75%,
        transparent 100%
      );
      -webkit-mask-image: linear-gradient(
        to bottom,
        black 45%,
        rgba(0, 0, 0, 0.5) 75%,
        transparent 100%
      );
    }

    /* Badge oculto en mobile */
    .hero-eyebrow {
      display: none;
    }

    /* Texto: anclado al fondo con padding ajustado para mostrar 2 botones */
    .hero-content {
      padding-top: 0;
      padding-bottom: 2rem;
      width: 100%;
      text-align: center;
    }

    .hero-title {
      font-size: clamp(1.9rem, 9vw, 2.8rem);
      margin-bottom: 0.6rem;
      line-height: 1.1;
    }

    .hero-subtitle {
      margin-bottom: 1.25rem;
      font-size: 0.95rem;
    }

    /* Botones apilados full-width */
    .hero-actions {
      flex-direction: column;
      width: 100%;
      gap: 0.75rem;
      margin-bottom: 0;
    }

    .btn-hero {
      width: 100%;
      justify-content: center;
    }

    .scroll-indicator {
      display: none;
    }

    /* Glow ambiental ajustado */
    .hero-ambient {
      bottom: 0;
      width: 100%;
      height: 200px;
    }
  }
</style>
