---
// BaseLayout.astro
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "DakyLabs — Cloud e IA",
  description = "Cloud, IA y herramientas de Google. Lo que construyo, lo que aprendo y lo que comparto.",
  ogImage = "/images/dakybot-hero.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageAbsolute = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="preload"
      as="image"
      imagesrcset="/images/dakybot-hero-500.webp 500w, /images/dakybot-hero-800.webp 800w, /images/dakybot-hero.webp 1024w"
      imagesizes="(max-width: 640px) 100vw, 520px"
      type="image/webp"
      fetchpriority="high"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="author" content="Santino Suntaxi — DakyLabs" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:locale" content="es_LA" />
    <meta property="og:site_name" content="DakyLabs" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Fonts (single <link> — fastest method) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;0,14..32,900;1,14..32,400&display=swap"
    />

    <slot name="head" />

    <!-- Analytics -->
    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="ada2f86b-57e3-4ff2-a19f-da038209c36e"></script>
  </head>
  <body>
    <slot />

    <!-- DakyBot — pega TODO este bloque antes de </body> en dakylabs.com (página Astro) -->
    <script is:inline data-bff="https://chat-bff-hitox6ucqa-ue.a.run.app">
/**
 * DakyBot — widget de chat embebible. JS vanilla + Shadow DOM (sin frameworks, ADR-0006).
 *
 * Garantías de seguridad (ver ADR-0004 / SECURITY.md):
 *  - Aislado en Shadow DOM: no toca ni es tocado por el DOM/CSS de la página anfitriona.
 *  - Cero secretos: solo obtiene un token de sesión de corta vida del BFF.
 *  - Nunca habla con GCP directamente; todo pasa por el BFF.
 *  - El markdown del bot se renderiza con escapeHtml PRIMERO (sin XSS).
 *
 * Uso (1 línea en la web del cliente):
 *   <script src="https://.../widget.js" data-bff="https://chat-bff-....run.app" defer><\/script>
 */
(function () {
  "use strict";

  const script = document.currentScript;
  const BFF = (script && script.getAttribute("data-bff")) || "";
  if (!BFF) return console.error("[widget] falta data-bff");

  let token = null;

  async function getSession() {
    const res = await fetch(`${BFF}/session`, { method: "POST" });
    if (!res.ok) throw new Error("session_failed");
    token = (await res.json()).token;
  }

  async function send(message, onChunk, onDone) {
    if (!token) await getSession();
    const res = await fetch(`${BFF}/chat`, {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify({ message, token }),
    });
    if (res.status === 401) {
      token = null;
      return send(message, onChunk, onDone);
    }
    if (!res.ok) {
      onChunk("Lo siento, el asistente no está disponible ahora mismo.");
      return onDone();
    }
    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let buf = "";
    const flush = (event) => {
      const data = event
        .split("\n")
        .filter((l) => l.startsWith("data:"))
        .map((l) => l.replace(/^data:\s?/, ""))
        .join("\n");
      if (data) onChunk(data);
    };
    for (;;) {
      const { value, done } = await reader.read();
      if (done) break;
      buf += decoder.decode(value, { stream: true });
      let i;
      while ((i = buf.indexOf("\n\n")) !== -1) {
        flush(buf.slice(0, i));
        buf = buf.slice(i + 2);
      }
    }
    if (buf.trim()) flush(buf);
    onDone();
  }

  function escapeHtml(s) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }

  // Markdown mínimo y SEGURO (escapa el HTML antes de aplicar formato).
  function mdToHtml(src) {
    const code = [];
    src = src.replace(/```[^\n]*\n?([\s\S]*?)```/g, (_, c) => {
      code.push(c.replace(/\n+$/, ""));
      return `@@C${code.length - 1}@@`;
    });

    const inline = (s) => escapeHtml(s)
      .replace(/`([^`]+)`/g, "<code>$1</code>")
      .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
      .replace(/(^|[^*])\*([^*\n]+)\*(?!\*)/g, "$1<em>$2</em>")
      .replace(/\[([^\]]+)\]\((https?:[^)\s]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');

    let html = "", list = null;
    const close = () => { if (list) { html += `</${list}>`; list = null; } };

    for (const raw of src.split(/\r?\n/)) {
      const line = raw.trim();
      if (!line) { close(); continue; }
      let m;
      if (/^@@C\d+@@$/.test(line)) { close(); html += line; }
      else if ((m = line.match(/^[-*•]\s+(.*)$/))) {
        if (list !== "ul") { close(); html += "<ul>"; list = "ul"; }
        html += `<li>${inline(m[1])}</li>`;
      } else if ((m = line.match(/^(\d+)[.)]\s+(.*)$/))) {
        if (list !== "ol") { close(); html += "<ol>"; list = "ol"; }
        html += `<li>${inline(m[2])}</li>`;
      } else if ((m = line.match(/^(#{1,3})\s+(.*)$/))) {
        close();
        const lvl = m[1].length + 2;
        html += `<h${lvl}>${inline(m[2])}</h${lvl}>`;
      } else {
        close();
        html += `<p>${inline(line)}</p>`;
      }
    }
    close();
    return html.replace(/@@C(\d+)@@/g, (_, i) => `<pre><code>${escapeHtml(code[i])}</code></pre>`);
  }

  function mount() {
    const host = document.createElement("div");
    host.id = "dakybot-widget";
    document.body.appendChild(host);
    const root = host.attachShadow({ mode: "closed" });

    root.innerHTML = `
      <style>
        :host {
          all: initial;
          --brand: #C0142A;
          --brand-press: #9e1022;
          --ink: #1d1d1f;
          --ink-soft: #6e6e73;
          --line: rgba(0,0,0,.09);
          --bg: #ffffff;
          --bg-soft: #f5f5f7;
          --font: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", system-ui, sans-serif;
        }
        * { box-sizing: border-box; }
        /* Resaltado de selección visible sobre CUALQUIER color de burbuja (al copiar texto). */
        ::selection { background: #fde047; color: #0f172a; }

        .launcher {
          position: fixed; bottom: 24px; right: 24px; width: 56px; height: 56px;
          border-radius: 50%; background: var(--brand); color: #fff; border: none; cursor: pointer;
          box-shadow: 0 8px 24px rgba(192,20,42,.30), 0 2px 6px rgba(0,0,0,.12);
          font-size: 24px; z-index: 2147483646;
          display: flex; align-items: center; justify-content: center;
          transition: transform .18s cubic-bezier(.2,.8,.2,1), box-shadow .18s;
          font-family: var(--font);
        }
        .launcher:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(192,20,42,.38), 0 3px 8px rgba(0,0,0,.14); }
        .launcher:active { transform: translateY(0); }
        .launcher.hidden { display: none; }

        .panel {
          position: fixed; bottom: 24px; right: 24px; width: 384px; max-width: calc(100vw - 32px);
          height: 580px; max-height: calc(100vh - 48px);
          display: none; flex-direction: column; z-index: 2147483647;
          background: var(--bg); border-radius: 20px; overflow: hidden;
          border: 0.5px solid var(--line);
          box-shadow: 0 24px 64px rgba(0,0,0,.18), 0 8px 20px rgba(0,0,0,.10);
          font-family: var(--font); color: var(--ink); -webkit-font-smoothing: antialiased;
        }
        .panel.open { display: flex; animation: pop .22s cubic-bezier(.2,.8,.2,1); }
        @keyframes pop { from { transform: translateY(16px) scale(.98); opacity: 0; } to { transform: none; opacity: 1; } }

        .header {
          background: var(--bg); border-bottom: 0.5px solid var(--line);
          padding: 13px 16px; display: flex; align-items: center; gap: 11px; flex-shrink: 0;
        }
        .header .avatar {
          width: 36px; height: 36px; border-radius: 50%;
          background: linear-gradient(145deg, #d81733, #9e1022); color: #fff;
          display: flex; align-items: center; justify-content: center; font-size: 18px;
          box-shadow: 0 2px 6px rgba(192,20,42,.32);
        }
        .header .ttl { font-size: 15px; font-weight: 600; letter-spacing: -.01em; color: var(--ink); line-height: 1.2; }
        .header .sub { font-size: 12px; color: var(--ink-soft); display: flex; align-items: center; gap: 5px; }
        .header .sub::before { content: ""; width: 7px; height: 7px; border-radius: 50%; background: #34c759; box-shadow: 0 0 0 2px rgba(52,199,89,.18); }
        .header .close {
          margin-left: auto; background: transparent; border: none; color: var(--ink-soft);
          font-size: 17px; cursor: pointer; width: 30px; height: 30px; border-radius: 50%;
          display: flex; align-items: center; justify-content: center; transition: background .15s, color .15s;
        }
        .header .close:hover { background: var(--bg-soft); color: var(--ink); }

        .log { flex: 1; overflow-y: auto; padding: 18px 16px; background: var(--bg-soft); display: flex; flex-direction: column; gap: 12px; }
        .msg {
          max-width: 82%; padding: 10px 14px; border-radius: 17px; font-size: 14px;
          line-height: 1.55; letter-spacing: -.003em; word-wrap: break-word;
        }
        .msg.user { align-self: flex-end; background: var(--brand); color: #fff; border-bottom-right-radius: 5px; white-space: pre-wrap; box-shadow: 0 1px 2px rgba(192,20,42,.22); }
        .msg.bot {
          align-self: flex-start; background: var(--bg); color: var(--ink);
          border: 0.5px solid var(--line); border-bottom-left-radius: 5px;
          box-shadow: 0 1px 2px rgba(0,0,0,.05); white-space: normal;
        }
        .msg.bot.typing { padding: 13px 15px; }
        .dots { display: inline-flex; gap: 5px; align-items: center; }
        .dots > span { width: 7px; height: 7px; border-radius: 50%; background: #b8b8be;
          animation: dakyblink 1.3s ease-in-out infinite both; }
        .dots > span:nth-child(2) { animation-delay: .18s; }
        .dots > span:nth-child(3) { animation-delay: .36s; }
        @keyframes dakyblink { 0%, 70%, 100% { opacity: .3; transform: scale(.8); } 35% { opacity: 1; transform: scale(1); } }
        .msg.bot > :first-child { margin-top: 0; }
        .msg.bot > :last-child { margin-bottom: 0; }
        .msg.bot p { margin: 0 0 8px; }
        .msg.bot ul, .msg.bot ol { margin: 6px 0; padding-left: 20px; }
        .msg.bot li { margin: 4px 0; padding-left: 2px; }
        .msg.bot li::marker { color: var(--brand); }
        .msg.bot strong { font-weight: 600; color: var(--ink); }
        .msg.bot em { font-style: italic; }
        .msg.bot a { color: var(--brand); text-decoration: none; border-bottom: 1px solid rgba(192,20,42,.35); }
        .msg.bot a:hover { border-bottom-color: var(--brand); }
        .msg.bot h3, .msg.bot h4, .msg.bot h5 { margin: 12px 0 5px; font-weight: 600; letter-spacing: -.01em; line-height: 1.3; }
        .msg.bot h3 { font-size: 15px; } .msg.bot h4, .msg.bot h5 { font-size: 14px; }
        .msg.bot code { background: #ececed; padding: 1.5px 5px; border-radius: 5px;
          font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; }
        .msg.bot pre { background: #1d1d1f; color: #f5f5f7; padding: 11px 13px; border-radius: 10px;
          overflow-x: auto; margin: 8px 0; }
        .msg.bot pre code { background: none; color: inherit; padding: 0; font-size: 12.5px; }

        .row { display: flex; gap: 9px; padding: 12px 14px; border-top: 0.5px solid var(--line); background: var(--bg); flex-shrink: 0; }
        input {
          flex: 1; border: 0.5px solid var(--line); border-radius: 21px; padding: 10px 16px; font-size: 14px; outline: none;
          font-family: inherit; color: var(--ink); background: var(--bg-soft);
          transition: background .15s, border-color .15s, box-shadow .15s;
        }
        input::placeholder { color: #9a9aa0; }
        input:focus { background: var(--bg); border-color: rgba(192,20,42,.5); box-shadow: 0 0 0 3.5px rgba(192,20,42,.12); }
        .send {
          border: none; background: var(--brand); color: #fff; width: 42px; height: 42px; border-radius: 50%;
          cursor: pointer; font-size: 17px; flex-shrink: 0; display: flex; align-items: center; justify-content: center;
          transition: background .15s, transform .15s;
        }
        .send:hover { background: var(--brand-press); }
        .send:active { transform: scale(.94); }

        .log::-webkit-scrollbar { width: 7px; }
        .log::-webkit-scrollbar-thumb { background: rgba(0,0,0,.18); border-radius: 4px; border: 2px solid var(--bg-soft); }
        .log::-webkit-scrollbar-thumb:hover { background: rgba(0,0,0,.28); }
      </style>

      <button class="launcher" id="launcher" aria-label="Abrir chat">💬</button>

      <div class="panel" id="panel">
        <div class="header">
          <div class="avatar">🤖</div>
          <div>
            <div class="ttl">DakyBot</div>
            <div class="sub">En línea · responde al instante</div>
          </div>
          <button class="close" id="close" aria-label="Cerrar">✕</button>
        </div>
        <div class="log" id="log"></div>
        <div class="row">
          <input id="q" placeholder="Escribe tu pregunta…" autocomplete="off" />
          <button class="send" id="s" aria-label="Enviar">➤</button>
        </div>
      </div>`;

    const launcher = root.getElementById("launcher");
    const panel = root.getElementById("panel");
    const log = root.getElementById("log");
    const q = root.getElementById("q");
    let greeted = false;

    function addMsg(who, text, opts) {
      const div = document.createElement("div");
      const typing = opts && opts.typing;
      div.className = `msg ${who}` + (typing ? " typing" : "");
      if (typing) div.innerHTML = '<span class="dots"><span></span><span></span><span></span></span>';
      else if (who === "bot") div.innerHTML = mdToHtml(text);
      else div.textContent = text;
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
      return div;
    }

    function open() {
      panel.classList.add("open");
      launcher.classList.add("hidden");
      if (!greeted) {
        addMsg("bot", "¡Hola! 🤖 Soy DakyBot. Mi misión es ayudarte — pregúntame sobre la información de esta página y sus artículos.");
        greeted = true;
      }
      q.focus();
    }
    function close() {
      panel.classList.remove("open");
      launcher.classList.remove("hidden");
    }

    launcher.addEventListener("click", open);
    root.getElementById("close").addEventListener("click", close);

    function ask() {
      const text = q.value.trim();
      if (!text) return;
      addMsg("user", text);
      q.value = "";
      const bot = addMsg("bot", "", { typing: true });

      let target = "", shown = 0, finished = false, started = false, last = 0, raf = 0;
      const SPEED = 48;

      const frame = (now) => {
        const dt = last ? Math.min((now - last) / 1000, 0.1) : 0;
        last = now;
        if (shown < target.length) {
          const rate = Math.min(SPEED + (target.length - shown) * 2.5, 220);
          shown = Math.min(target.length, shown + rate * dt);
          bot.innerHTML = mdToHtml(target.slice(0, Math.floor(shown)));
          log.scrollTop = log.scrollHeight;
        }
        if (finished && shown >= target.length) { raf = 0; return; }
        raf = requestAnimationFrame(frame);
      };

      send(
        text,
        (chunk) => {
          target += chunk;
          if (!started) {
            started = true;
            bot.classList.remove("typing");
            bot.innerHTML = "";
            last = 0;
            raf = requestAnimationFrame(frame);
          }
        },
        () => {
          finished = true;
          if (!started) { bot.classList.remove("typing"); bot.innerHTML = mdToHtml("No obtuve respuesta. Intenta de nuevo."); }
        },
      ).catch(() => {
        finished = true;
        if (raf) cancelAnimationFrame(raf);
        bot.classList.remove("typing");
        bot.textContent = "Error de conexión. Intenta de nuevo.";
      });
    }
    root.getElementById("s").addEventListener("click", ask);
    q.addEventListener("keydown", (e) => e.key === "Enter" && ask());
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", mount);
  } else {
    mount();
  }
})();
    </script>
  </body>
</html>
