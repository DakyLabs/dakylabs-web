---
// src/pages/prueba-maps.astro
// ⚠️ PÁGINA DE PRUEBA TEMPORAL — validar la API key de Google Maps. BORRAR después de probar.
// No está enlazada en la navegación. URL: /prueba-maps
const GOOGLE_MAPS_KEY = "AIzaSyAYYxIruQSOw7dTH-KIB-XKvIaaB5Erd6U";
const mapsSrc = `https://maps.googleapis.com/maps/api/js?key=${GOOGLE_MAPS_KEY}&callback=initMap&v=weekly`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Prueba Google Maps — DakyLabs</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
        background: #0f172a; color: #e2e8f0; min-height: 100vh;
        display: flex; flex-direction: column;
      }
      header { padding: 18px 22px; border-bottom: 1px solid #1e293b; }
      header h1 { font-size: 17px; font-weight: 600; }
      header p { font-size: 13px; color: #94a3b8; margin-top: 3px; }
      .status {
        margin: 16px 22px; padding: 12px 16px; border-radius: 10px;
        font-size: 14px; line-height: 1.5; border: 1px solid #334155; background: #1e293b;
      }
      .status.ok { border-color: #16a34a; background: rgba(22,163,74,.12); color: #86efac; }
      .status.err { border-color: #dc2626; background: rgba(220,38,38,.12); color: #fca5a5; }
      .status code { background: rgba(148,163,184,.18); padding: 1px 6px; border-radius: 5px; font-size: 12.5px; }
      #map { flex: 1; min-height: 420px; margin: 0 22px 22px; border-radius: 12px; overflow: hidden; background: #1e293b; }
    </style>
  </head>
  <body>
    <header>
      <h1>🗺️ Prueba de Google Maps API key</h1>
      <p>Página temporal para validar la key. No enlazada en el sitio · <code>noindex</code></p>
    </header>

    <div id="status" class="status">Cargando la API de Google Maps…</div>
    <div id="map"></div>

    <script is:inline>
      const statusEl = document.getElementById("status");
      const origin = location.origin;

      // Diagnóstico: Google imprime el código exacto del error en console.error.
      // Lo interceptamos para mostrarlo en pantalla junto con la URL a autorizar.
      const CAUSAS = {
        RefererNotAllowedMapError: "El origen/URL de esta página NO está en la lista de referrers permitidos de la key.",
        ApiNotActivatedMapError: "La API 'Maps JavaScript API' no está HABILITADA en el proyecto de GCP.",
        BillingNotEnabledMapError: "El proyecto NO tiene facturación activa (Maps exige billing habilitado).",
        ApiTargetBlockedMapError: "Las restricciones de API de la key BLOQUEAN Maps JavaScript API.",
        InvalidKeyMapError: "La key es inválida.",
        ExpiredKeyMapError: "La key expiró.",
        MissingKeyMapError: "Falta la key en la petición.",
      };

      function mostrarError(code, msg) {
        const authUrl = (msg.match(/authorized:\s*(\S+)/i) || [])[1];
        statusEl.className = "status err";
        statusEl.innerHTML =
          "❌ <strong>" + code + "</strong> — origen <code>" + origin + "</code><br>" +
          (CAUSAS[code] || "La key fue rechazada.") +
          (authUrl ? "<br>➡️ URL a autorizar en la restricción de la key: <code>" + authUrl + "</code>" : "");
      }

      const _err = console.error.bind(console);
      console.error = function () {
        const msg = Array.prototype.join.call(arguments, " ");
        for (const code in CAUSAS) {
          if (msg.indexOf(code) !== -1) { mostrarError(code, msg); break; }
        }
        _err.apply(console, arguments);
      };

      // Fallback si Google no logueó un código reconocible.
      window.gm_authFailure = function () {
        if (statusEl.className.indexOf("err") === -1) {
          statusEl.className = "status err";
          statusEl.innerHTML =
            "❌ <strong>La key fue RECHAZADA</strong> en este origen (<code>" + origin + "</code>).<br>" +
            "Revisa la consola del navegador para el código exacto (referrer, API, facturación o key inválida).";
        }
      };

      // Callback de éxito de la carga del script de Maps.
      window.initMap = function () {
        try {
          const quito = { lat: -0.1807, lng: -78.4678 };
          const map = new google.maps.Map(document.getElementById("map"), {
            center: quito,
            zoom: 12,
          });
          new google.maps.Marker({ position: quito, map, title: "Quito, Ecuador" });
          statusEl.className = "status ok";
          statusEl.innerHTML =
            "✅ <strong>La key FUNCIONA</strong> en este origen (<code>" + origin + "</code>). El mapa cargó correctamente.";
        } catch (e) {
          statusEl.className = "status err";
          statusEl.textContent = "⚠️ La API cargó pero hubo un error al renderizar el mapa: " + e.message;
        }
      };
    </script>

    <script is:inline async defer src={mapsSrc}></script>
  </body>
</html>
