---
// src/pages/eventos.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FeaturedSidebar from "../components/FeaturedSidebar.astro";
import AdsSidebar from "../components/AdsSidebar.astro";
---

<BaseLayout
  title="Eventos — DakyLabs"
  description="Hablo en eventos, meetups y conferencias sobre IA e infraestructura Cloud u otros temas sobre los cuales tengo experiencia. Si quieres invitarme, aquí está la info."
>
  <Header />
  <main id="eventos-main">
    <div class="site-two-col" style="padding-top: 3rem;">
      <div class="site-col-center">
        <div class="page-hero-inner" aria-labelledby="eventos-title">
          <span class="section-label">Eventos & Charlas</span>
          <h1 id="eventos-title">Hablo en público.<br />A veces incluso bien.</h1>
          <p class="page-hero-sub">
            Me gusta las charlas técnicas sobre temas de nube, IA y herramientas que
            utilizo en mi día a día.
          </p>
        </div>

    <!-- Invite info -->
    <section
      class="section"
      style="padding-top: 0;"
      aria-label="Información para invitaciones"
    >
      <div>
        <div class="invite-block glass-card">
          <h2 class="invite-title">¿Tienes una idea loca?</h2>
          <p>
            Disfruto dictar charlas y participar activamente en las comunidades. Si quieres que sea parte de tu evento, meetup o podcast
           o simplemente tienes una idea fuera de lo común escríbeme.
          </p>
          <div class="invite-actions">
            <a
              href="mailto:contacto@dakylabs.com"
              class="btn btn-primary invite-cta"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                <path d="m3 7 9 6 9-6"></path>
              </svg>
              contacto@dakylabs.com
            </a>
            <a
              href="https://discord.com/invite/RJtQCFCgy"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost invite-cta"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"
                ></path>
              </svg>
              Discord
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Photos -->
    <section class="section" aria-label="Fotos de eventos">
      <div>
        <div
          class="section-header"
          style="text-align:left; margin-bottom: 1.75rem;"
        >
          <span class="section-label">Galería</span>
          <h2>En acción.</h2>
        </div>
        <div class="photos-grid">
          <div class="photo-item">
            <img
              src="/images/eventos/evento-01.jpg"
              alt="Santino Suntaxi en evento técnico"
              loading="lazy"
            />
          </div>
          <div class="photo-item">
            <img
              src="/images/eventos/evento-02.jpg"
              alt="Santino Suntaxi hablando en conferencia"
              loading="lazy"
            />
          </div>
          <div class="photo-item">
            <img
              src="/images/eventos/evento-03.jpg"
              alt="Santino Suntaxi en meetup de Cloud"
              loading="lazy"
            />
          </div>
          {/*
          <div class="photo-item">
            <img
              src="/images/eventos/evento-04.jpg"
              alt="Santino Suntaxi en evento técnico"
              loading="lazy"
            />
          </div>
          <div class="photo-item">
            <img
              src="/images/eventos/evento-05.jpg"
              alt="Santino Suntaxi hablando en conferencia"
              loading="lazy"
            />
          </div>
          <div class="photo-item">
            <img
              src="/images/eventos/evento-06.jpg"
              alt="Santino Suntaxi en meetup de Cloud"
              loading="lazy"
            />
          </div>
          */}
        </div>
      </div>
    </section>

        <FeaturedSidebar />
      </div>{/* end .site-col-center */}
      <aside class="site-col-right">
        <AdsSidebar />
      </aside>
    </div>{/* end .site-two-col */}
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Page Hero ─── */
  .page-hero-inner {
    padding-bottom: 2rem;
    margin-bottom: 1.5rem;
  }

  .page-hero-inner h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .page-hero-sub {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 55ch;
    line-height: 1.75;
  }

  /* ── Invite block ─── */
  .invite-block {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .invite-title {
    font-size: 1.4rem;
    letter-spacing: -0.025em;
    margin: 0;
  }

  .invite-block > p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin: 0;
    max-width: 60ch;
  }

  .invite-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .invite-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  /* ── Photos grid ─── */
  .photos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .photo-item {
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 3/4;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-subtle);
  }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(15%) contrast(1.05);
    transition:
      filter 0.3s ease,
      transform 0.4s ease;
    display: block;
  }

  .photo-item:hover img {
    filter: grayscale(0%) contrast(1.05);
    transform: scale(1.02);
  }

  @media (max-width: 768px) {
    .invite-block {
      padding: 1.75rem;
    }

    .photos-grid {
      grid-template-columns: 1fr;
    }

    .invite-actions {
      flex-direction: column;
    }

    .invite-cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
