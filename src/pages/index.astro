---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import BlogCard from "../components/BlogCard.astro";
import FeaturedSidebar from "../components/FeaturedSidebar.astro";
import AdsSidebar from "../components/AdsSidebar.astro";
import { talks } from "../data/talks";

import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = sortedPosts.slice(0, 3);

// Destacados: primero los marcados como featured, luego los más recientes
const featuredPosts = [
  ...sortedPosts.filter((p) => p.data.featured),
  ...sortedPosts.filter((p) => !p.data.featured),
].slice(0, 3);

const CATEGORIES = ["GCP", "Workspace", "IA", "Ciberseguridad", "Open Source"] as const;
const postsByCategory = CATEGORIES.map((name) => ({
  name,
  posts: sortedPosts.filter((p) => p.data.category === name).slice(0, 5),
})).filter((cat) => cat.posts.length > 0);

// Proyectos próximamente
/*
const projects = [
  {
    tag: 'IA · Vertex AI',
    title: 'Clasificación masiva de documentos legales',
    description: '...',
    stack: ['Vertex AI', 'BigQuery', 'Cloud Storage'],
  },
];
*/
---

<BaseLayout>
  <Header />
  <main id="main-content" class="home-page">
    <!-- ══ CONTENIDO ════════════════════════════════════════════ -->
    <div class="site-two-col">

      <!-- Columna centro: hero + contenido -->
      <div class="site-col-center">
        <Hero />

    <!-- ══ POR CATEGORÍA ════════════════════════════════════════ -->
    {
      false && postsByCategory.length > 0 && (
        <section
          class="section-inner"
          id="por-categoria"
          aria-labelledby="cat-heading"
        >
            <div class="section-header">
              <span class="section-label">Explorar</span>
              <h2 id="cat-heading">Por categoría.</h2>
              <p class="section-subtitle">
                Encuentra artículos según el área que te interesa.
              </p>
            </div>
            <div class="cat-grid">
              {postsByCategory.map((cat) => (
                <div class="cat-block glass-card">
                  <div class="cat-header">
                    <span class="badge">{cat.name}</span>
                  </div>
                  <ul class="cat-posts" role="list">
                    {cat.posts.map((post) => (
                      <li class="cat-post-item">
                        <a href={`/blog/${post.id}`} class="cat-post-link">
                          <div class="cat-thumb" aria-hidden="true">
                            {post.data.image ? (
                              <img src={post.data.image} alt="" loading="lazy" width="52" height="40" />
                            ) : (
                              <div class="cat-thumb-placeholder" data-cat={post.data.category} />
                            )}
                          </div>
                          <div class="cat-post-text">
                            <span class="cat-post-title">{post.data.title}</span>
                            <span class="cat-post-date">
                              {(() => {
                                const raw = post.data.pubDate.toLocaleDateString("es-MX", {
                                  weekday: "long",
                                  day: "numeric",
                                  month: "long",
                                  year: "numeric",
                                });
                                return raw.charAt(0).toUpperCase() + raw.slice(1);
                              })()}
                            </span>
                          </div>
                        </a>
                      </li>
                    ))}
                  </ul>
                  <a href={`/blog?cat=${cat.name}`} class="cat-ver-todos">
                    Ver todos en {cat.name} →
                  </a>
                </div>
              ))}
            </div>
        </section>
      )
    }

    <!-- ══ ÚLTIMAS CHARLAS ══════════════════════════════════════ -->
    {talks.length > 0 && (
      <section class="section-inner charlas-section">
        {talks.slice(0, 1).map((talk) => (
          <div class="charla-embed-wrap">
            <iframe
              src={`https://www.youtube.com/embed/${talk.youtube}`}
              title={talk.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
              class="charla-iframe"
            ></iframe>
            <div class="charla-meta">
              <span class="badge">{talk.event}</span>
              <span class="charla-location">📍 {talk.location} · {talk.date}</span>
              <p class="charla-title">{talk.title}</p>
            </div>
          </div>
        ))}
      </section>
    )}

    <!-- ══ FILOSOFÍA ════════════════════════════════════════════ -->
    <section class="section-inner" id="filosofia" aria-labelledby="filosofia-heading">
        <div class="section-header">
          <span class="section-label">DakyLabs</span>
          <h2 id="filosofia-heading">Los pilares del canal.</h2>
          <p class="section-subtitle">
            DakyLabs es un espacio de aprendizaje para la comunidad.
          </p>
        </div>

        <div class="filosofia-grid animate-fade-up">
          <div class="filosofia-item">
            <span class="filosofia-num">01</span>
            <h3>Charlar</h3>
            <p>
              Dar charlas en eventos técnicos, meetups y conferencias. Hablar de
              lo que sé con honestidad.
            </p>
          </div>
          <div class="filosofia-item">
            <span class="filosofia-num">02</span>
            <h3>Comunidad</h3>
            <p>
              Participar activamente en comunidades técnicas. Responder preguntas y aportar.
            </p>
          </div>
          <div class="filosofia-item">
            <span class="filosofia-num">03</span>
            <h3>Conocimiento</h3>
            <p>
              Compartir lo que aprendo en mi día a día. Lo que
              funciona, lo que falla y por qué.
            </p>
          </div>
          <div class="filosofia-item">
            <span class="filosofia-num">04</span>
            <h3>Seguridad</h3>
            <p>
              La seguridad no es un módulo que se agrega al final. Es una
              perspectiva que aplica desde el diseño de cualquier sistema.
            </p>
          </div>
        </div>
    </section>

    <!-- ══ DISCORD CTA ═══════════════════════════════════════ -->
    <section class="section-sm discord-section" aria-label="Comunidad">
        <div class="discord-card glass-card">
          <div class="discord-glow" aria-hidden="true"></div>
          <span class="section-label">Comunidad</span>
          <h2 class="discord-title">Comunidad</h2>
          <p>
            Si tienes preguntas técnicas sobre cloud, IA o quieres conversar
            sobre algún tema o proyecto, puedes encontrarme en Discord.
          </p>
          <a
            href="https://discord.com/invite/RJtQCFCgy"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
            id="discord-cta-btn"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="currentColor"
              style="flex-shrink:0"
            >
              <path
                d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"
              ></path>
            </svg>
            Unirse al Discord
          </a>
        </div>
    </section>

        <!-- Entradas populares -->
        <FeaturedSidebar />

        <!-- ══ EASTER EGG: invita a jugar el arcade ═══════════════ -->
        <section class="section-sm egg-section" aria-label="Juego arcade">
          <div class="egg-card">
            <div class="egg-content">
              <span class="egg-emoji" aria-hidden="true">🎮</span>
              <div class="egg-text">
                <h3 class="egg-title">¿Llegaste hasta aquí?</h3>
                <p>Te mereces algo extra. Defiende el planeta Daky de los invasores en modo arcade.</p>
              </div>
            </div>
            <button type="button" class="btn btn-ghost egg-btn" id="home-play-btn">
              Jugar Daky Invaders
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" style="margin-left: 6px;">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
        </section>
      </div>{/* end .site-col-center */}

      <!-- Columna derecha: anuncios -->
      <aside class="site-col-right">
        <AdsSidebar />
      </aside>

    </div>{/* end .site-two-col */}

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero: largo hasta el nivel del segundo anuncio, robot más grande ─── */
  #main-content :global(.hero) {
    width: 100%;
    min-height: 826px;
    margin-top: 108px;
    position: relative;
    left: auto;
    transform: none;
    border-radius: var(--radius-md);
    margin-bottom: 0;
  }

  #main-content :global(.site-col-right) {
    margin-top: 30px;
  }

  #main-content :global(.hero-bot-wrapper) {
    align-items: stretch;
  }

  #main-content :global(.hero-bot) {
    width: auto;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* ── Section inner (sin .container, ya dentro del layout) ─── */
  .section-inner {
    padding-block: 1.5rem 0;
  }

  /* ── Section headers ─── */
  .section-header {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: 3.5rem;
  }

  .section-subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-top: 0.75rem;
  }

  /* ── Services Grid ─── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Filosofía Grid ─── */
  .filosofia-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
    margin-bottom: 1rem;
  }

  .filosofia-item {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .filosofia-num {
    font-size: 0.7rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--accent);
    letter-spacing: 0.1em;
  }

  .filosofia-item h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .filosofia-item p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .filosofia-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .filosofia-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
  .feature-strip {
    padding-block: 3rem;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    position: relative;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(192, 20, 42, 0.02) 0%,
      transparent 100%
    );
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .feature-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--accent-subtle);
    border: 1px solid var(--border-accent-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--accent);
  }

  .feature-item h4 {
    font-size: 0.9rem;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }

  .feature-item p {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  /* ── Blog Grid ─── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* ── Section footer CTA ─── */
  .section-footer-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* ── Final CTA Section ─── */
  .cta-section {
    position: relative;
    z-index: 1;
  }

  .cta-card {
    padding: 3.5rem;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .cta-bot-glow {
    position: absolute;
    right: -100px;
    top: 50%;
    transform: translateY(-50%);
    width: 400px;
    height: 400px;
    background: radial-gradient(
      circle,
      rgba(192, 20, 42, 0.08) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .cta-content {
    max-width: 560px;
    position: relative;
    z-index: 1;
  }

  .cta-content h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    margin-bottom: 0.75rem;
  }

  .cta-content p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── Responsive ─── */
  @media (max-width: 1024px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }

    .bio-card {
      padding: 2rem 1.5rem;
    }
  }

  /* ── Projects Grid ─── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .project-card {
    padding: 2rem;
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .project-card:hover {
    transform: translateY(-2px);
  }

  .project-tag {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .project-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
    margin: 0;
  }

  .project-metrics {
    display: flex;
    gap: 1.5rem;
    padding: 0.875rem 0;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .metric-value {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    font-family: var(--font-mono);
  }

  .metric-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .stack-chip {
    font-size: 0.7rem;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-xs);
    background: var(--accent-subtle);
    border: 1px solid var(--border-accent-soft);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-weight: 500;
  }

  .project-accent-line {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--accent),
      transparent
    );
    opacity: 0;
    transition: opacity 0.3s;
  }

  .project-card:hover .project-accent-line {
    opacity: 1;
  }

  /* ── Discord CTA ─── */
  .discord-section {
    padding-bottom: 5rem;
  }

  .discord-card {
    text-align: center;
    padding: 3.5rem 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }

  .discord-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 60% 60% at 50% 50%,
      rgba(88, 101, 242, 0.06) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .discord-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    letter-spacing: -0.03em;
    position: relative;
    z-index: 1;
  }

  .discord-card .section-label,
  .discord-card p,
  .discord-card .btn {
    position: relative;
    z-index: 1;
  }

  .discord-card p {
    max-width: 50ch;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .discord-card .btn {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }

  @media (max-width: 1024px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .discord-card {
      padding: 2.5rem 1.75rem;
    }
  }

  /* ── Últimas charlas (embed) ─── */
  .charlas-section {
    padding-block: 2.5rem 0;
  }

  .charla-embed-wrap {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    background: var(--bg-card);
  }

  .charla-iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
  }

  .charla-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 1.25rem 0.75rem;
  }

  .charla-location {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .charla-title {
    width: 100%;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-secondary);
    line-height: 1.45;
    margin: 0;
    padding-bottom: 0.25rem;
  }

  /* ── Por Categoría ─── */
  .cat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .cat-block {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cat-posts {
    list-style: none;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .cat-post-item + .cat-post-item {
    border-top: 1px solid var(--border-subtle);
  }

  .cat-post-link {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.65rem 0;
    text-decoration: none;
  }

  /* Thumbnail pequeño */
  .cat-thumb {
    width: 38px;
    height: 30px;
    border-radius: var(--radius-xs);
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid var(--border-subtle);
    margin-top: 2px;
  }

  .cat-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .cat-post-link:hover .cat-thumb img {
    transform: scale(1.06);
  }

  .cat-thumb-placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .cat-thumb-placeholder[data-cat="GCP"]            { background: #4285F4; }
  .cat-thumb-placeholder[data-cat="IA"]             { background: #34A853; }
  .cat-thumb-placeholder[data-cat="Workspace"]      { background: #FA7B17; }
  .cat-thumb-placeholder[data-cat="Ciberseguridad"] { background: #8B5CF6; }
  .cat-thumb-placeholder[data-cat="Open Source"]    { background: #555555; }

  .cat-post-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .cat-post-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.45;
    transition: color 0.2s;
  }

  .cat-post-link:hover .cat-post-title {
    color: var(--accent);
  }

  .cat-post-date {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .cat-ver-todos {
    font-size: 0.775rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border-subtle);
